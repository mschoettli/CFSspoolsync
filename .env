# ─────────────────────────────────────────────────────────────────────────────
# CFSspoolsync – Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── Printer ───────────────────────────────────────────────────────────────────

# IP address of your Creality K2 printer
K2_HOST=192.168.1.100

# SSH user on the printer (default: root)
K2_SSH_USER=root

# Absolute path to the SSH private key on the Docker host
# Create with: ssh-keygen -t ed25519 -f /root/.ssh/id_k2 -N ""
K2_SSH_KEY=/root/.ssh/id_k2

# Moonraker API URL - do not delete http://
MOONRAKER_URL=http://192.168.1.100:7125

# Path to the CFS material JSON file on the printer
CFS_JSON_PATH=/mnt/UDISK/creality/userdata/box/material_box_info.json


# ── App ───────────────────────────────────────────────────────────────────────

# Port the web UI is available on (default: 8080)
PORT=8080

# SQLite database path inside the container
DATABASE_URL=sqlite:////app/data/cfs.db

# App locale
TIMEZONE=Europe/Zurich

# Optional tuning
MOONRAKER_POLL_INTERVAL=10
DISABLE_MOONRAKER_POLLING=0
OCR_TIMEOUT_SECONDS=60
OCR_HTTP_TIMEOUT_SECONDS=90
OCR_WARMUP=1
OCR_DEBUG=0
OCR_MAX_VARIANTS=6
OCR_CONFIDENCE_ACCEPTED=0.8
OCR_CONFIDENCE_LOW=0.55
OCR_ENABLE_CLOUD_FALLBACK=1
OCR_PROVIDER_1=openai
OCR_PROVIDER_2=claude
OCR_CLOUD_TIMEOUT_SECONDS=6
OCR_TOTAL_BUDGET_SECONDS=30
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
