# App
APP_NAME=CFSspoolsync
TIMEZONE=Europe/Zurich
LANGUAGE=de
DATETIME_LOCALE=de-DE
CORS_ALLOW_ORIGINS=http://192.168.178.201:5173,http://localhost:5173,http://127.0.0.1:5173
UI_THEME=dark
SETTINGS_ADMIN_TOKEN=

# Backend
BACKEND_PORT=8080
IMAGE_TAG=main
DATABASE_URL=postgresql+psycopg2://cfs:cfs@db:5432/cfsspoolsync
MOONRAKER_URL=http://192.168.178.192:7125
TELEMETRY_POLL_SECONDS=2.0
TELEMETRY_OFFLINE_GRACE_CYCLES=3
DEFAULT_FILAMENT_DIAMETER_MM=1.75
DEFAULT_FILAMENT_DENSITY=1.24
MAX_FILAMENT_RAW_DELTA_MM=4000

# CFS Agent
CFS_AGENT_URL=
CFS_AGENT_TOKEN=

# Camera
CAMERA_STREAM_URL=http://192.168.178.192:7125
