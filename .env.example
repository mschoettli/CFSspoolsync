# Printer
K2_HOST=192.168.1.100
K2_SSH_USER=root
K2_SSH_KEY_HOST=./secrets/id_k2
K2_SSH_KEY=/root/.ssh/id_k2
MOONRAKER_URL=http://192.168.1.100:7125
CFS_JSON_PATH=/mnt/UDISK/creality/userdata/box/material_box_info.json

# App
PORT=8080
DATABASE_URL=sqlite:////app/data/cfs.db
