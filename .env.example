# -----------------------------------------------------------
# CFSspoolsync - Configuration
# -----------------------------------------------------------
# Copy this file to .env and adjust the values.

# ---- Registry ----
# If you use your own fork, set this to your GHCR namespace.
# Default: ghcr.io/mschoettli
REGISTRY=ghcr.io/mschoettli
TAG=latest

# ---- Ports ----
# Port where the web UI is reachable (http://<host>:<HTTP_PORT>)
HTTP_PORT=8088

# ---- CFS / Moonraker ----
# Leave empty for simulator mode (randomly jittering sensor values).
# For live mode: IP address or hostname of your K2 Combo.
CFS_MOONRAKER_HOST=
CFS_MOONRAKER_PORT=7125

# ---- Timezone (for Watchtower scheduling and history timestamps) ----
TZ=Europe/Zurich

# ---- OCR / LLM (server-side only) ----
# Optional API keys for OCR post-processing fallback.
# Keys stay in backend only and are never exposed to the browser.
CFS_OPENAI_API_KEY=
CFS_ANTHROPIC_API_KEY=
CFS_OCR_ENABLE_CLOUD_FALLBACK=true


