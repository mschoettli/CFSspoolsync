OCR_HTTP_TIMEOUT_SECONDS=25
OCR_WARMUP=1
OCR_DEBUG=0
OCR_MAX_VARIANTS=6
OCR_CONFIDENCE_ACCEPTED=0.8
OCR_CONFIDENCE_LOW=0.55
OCR_ENABLE_CLOUD_FALLBACK=1
OCR_PROVIDER_1=openai
OCR_PROVIDER_2=claude
OCR_CLOUD_TIMEOUT_SECONDS=3.5
OCR_TOTAL_BUDGET_SECONDS=15
OPENAI_API_KEY=
