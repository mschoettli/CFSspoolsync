# App
APP_NAME=CFSspoolsync
TIMEZONE=Europe/Zurich
LANGUAGE=de
DATETIME_LOCALE=de-DE

# Backend
BACKEND_PORT=8080
DATABASE_URL=postgresql+psycopg2://cfs:cfs@db:5432/cfsspoolsync
MOONRAKER_URL=http://192.168.178.192:7125
TELEMETRY_POLL_SECONDS=2.0
DEFAULT_FILAMENT_DIAMETER_MM=1.75
DEFAULT_FILAMENT_DENSITY=1.24
MAX_FILAMENT_RAW_DELTA_MM=4000

# CFS Agent (no SSH in v3)
CFS_AGENT_URL=
CFS_AGENT_TOKEN=

# Camera
CAMERA_STREAM_URL=
CAMERA_WEBRTC_SIGNAL_URL=

# OCR
OCR_ENABLE_CLOUD_FALLBACK=1
OCR_PROVIDER_1=openai
OCR_PROVIDER_2=claude
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080

# Postgres
POSTGRES_DB=cfsspoolsync
POSTGRES_USER=cfs
POSTGRES_PASSWORD=cfs
