# -----------------------------------------------------------
# CFSspoolsync — Konfiguration
# -----------------------------------------------------------
# Kopiere diese Datei nach .env und passe die Werte an.

# ---- Registry ----
# Wenn du deinen eigenen Fork nutzt, setze das auf deinen GHCR-Namespace.
# Default: ghcr.io/mschoettli
REGISTRY=ghcr.io/mschoettli
TAG=latest

# ---- Ports ----
# Port auf dem die Web-UI erreichbar ist (http://<host>:<HTTP_PORT>)
HTTP_PORT=8088

# ---- CFS / Moonraker ----
# Leer lassen für Simulator-Modus (zufällig wobbelnde Sensorwerte).
# Für Live-Betrieb: IP oder Hostname deines K2 Combo.
CFS_MOONRAKER_HOST=
CFS_MOONRAKER_PORT=7125

# ---- Zeitzone (für Watchtower-Scheduling und History-Timestamps) ----
TZ=Europe/Zurich

# ---- OCR / LLM (server-side only) ----
# Optional API keys for OCR post-processing fallback.
# Keys stay in backend only and are never exposed to the browser.
CFS_OPENAI_API_KEY=
CFS_ANTHROPIC_API_KEY=
CFS_OCR_ENABLE_CLOUD_FALLBACK=true

